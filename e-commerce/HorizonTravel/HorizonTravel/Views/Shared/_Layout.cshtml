<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HorizonTravel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HorizonTravel.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Geologica:wght,CRSV@100..900,0&family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Share+Tech&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container-fluid">

                <a class="navbar-brand">
                    <img src="./lib/logo horizon.jpg" alt="Logo" width="60" height="54" class="d-inline-block align-text-center">
                    <span class="texto1">Horizon</span> <span class="texto2">Travel</span>
                </a>


                <!-- menu responsivo -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>


                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" style="color: #000;" asp-area="" asp-controller="Home" asp-action="Index">Pacotes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" style="color: #000;" asp-area="" asp-controller="" asp-action="">Destinos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" style="color: #000;" asp-area="" asp-controller="" asp-action="">Contatos</a>
                        </li>
                        <li class="nav-item me-5">
                            <a class="nav-link" style="color: #000;" asp-area="" asp-controller="" asp-action="">Sobre</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link me-3"><button type="button" class="btn btn-login btn-sm">Login</button></a>
                        </li>
                        <li class="nav-item" href="#">
                            <a class="nav-link"><i class="bi-cart3 fs-2 me-3"></i></a>
                        </li>
                    </ul>
                </div>


            </div>
        </nav>
    </header>


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <footer class="border-top footer py-4">
        <div class="container">
            <div class="row align-items-start">

                <div class="col">
                    <a class="imagem-logo"><img src="./lib/logo horizon.jpg" alt="logo" width="90" height="85"></a>
                    <p class="card-copy">&copy; 2026</p>

                </div>

                <div class="col">
                    <h6 class="card-title">Horizon Travel</h6>
                    <p class="card-text text-nowrap">
                        Lorem ipsum dolor sit amet,consectetur<br /> adipiscing elit.
                        Lorem ipsum dolor sit amet,<br />consectetur adipiscing elit.
                        Lorem ipsum dolor sit amet,<br />consectetur adipiscing elit.
                    </p>
                </div>

                <div class="col me-5">
                    <h6 class="card-title">Sobre</h6>
                    <p class="card-text text-nowrap">
                        Lorem ipsum dolor sit amet,<br /> consectetur adipiscing elit.
                    </p>
                </div>
                
                <div class="col align-items-center">
                    <h6 class="card-title">Contatos</h6>
                    <p class="card-text text-nowrap">
                        Entre em contato para avaliações e<br /> dúvidas, e siga nossas redes.<br /> HorizonTravel@gmail.com
                    </p>
                    <a class="icon" href="#"><i class="bi bi-instagram fs-4 ms-3 me-3" style="color: #fff"></i></a>
                    <a class="icon" href="#"><i class="bi bi-facebook fs-4 me-3" style="color: #fff"></i></a>
                    <a class="icon" href="#"><i class="bi bi-whatsapp fs-4 me-3" style="color: #fff"></i></a>
                </div>
            </div>

            </div>
            
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
